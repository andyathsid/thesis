  booktitle = {2025 8th {{International Conference}} on {{Artificial Intelligence}} and {{Big Data}} ({{ICAIBD}})},
  author = {Yu, Chaojia and Cheng, Zihan and Cui, Hanwen and Gao, Yishuo and Luo, Zexu and Wang, Yijin and Zheng, Hangbin and Zhao, Yong},
  date = {2025-05-23},
