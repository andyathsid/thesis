@online{singhFarmerChatScalingAIPowered2024,
  title = {Farmer.{{Chat}}: {{Scaling AI-Powered Agricultural Services}} for {{Smallholder Farmers}}},
  shorttitle = {Farmer.{{Chat}}},
  author = {Singh, Namita and Wang'ombe, Jacqueline and Okanga, Nereah and Zelenska, Tetyana and Repishti, Jona and K, Jayasankar G. and Mishra, Sanjeev and Manokaran, Rajsekar and Singh, Vineet and Rafiq, Mohammed Irfan and Gandhi, Rikin and Nambi, Akshay},
  date = {2024-09-13},
  eprint = {2409.08916},
