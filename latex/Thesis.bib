@online{esRagasAutomatedEvaluation2025,
  title = {Ragas: {{Automated Evaluation}} of {{Retrieval Augmented Generation}}},
  shorttitle = {Ragas},
  author = {Es, Shahul and James, Jithin and Espinosa-Anke, Luis and Schockaert, Steven},
