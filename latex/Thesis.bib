@article{liuCrossModalDataFusion2025,
  title = {Cross-{{Modal Data Fusion}} via {{Vision-Language Model}} for {{Crop Disease Recognition}}},
  author = {Liu, Wenjie and Wu, Guoqing and Wang, Han and Ren, Fuji},
  date = {2025-01},
