@article{yueImprovedYOLOv8SegNetwork2023,
  title = {Improved {{YOLOv8-Seg Network}} for {{Instance Segmentation}} of {{Healthy}} and {{Diseased Tomato Plants}} in the {{Growth Stage}}},
  author = {Yue, Xiang and Qi, Kai and Na, Xinyi and Zhang, Yang and Liu, Yanhua and Liu, Cuihong},
