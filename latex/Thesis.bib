@article{gulmezComprehensiveReviewConvolutional2025,
  title = {A {{Comprehensive Review}} of {{Convolutional~Neural~Networks}}~Based {{Disease Detection Strategies}} in {{Potato Agriculture}}},
  author = {Gülmez, Burak},
  date = {2025-06-01},
