  keywords = {Computer Science - Computation and Language,Computer Science - Machine Learning,Statistics - Machine Learning},
  file = {C\:\\Users\\Andakara\\Zotero\\storage\\CPWTXQSA\\Lepikhin et al. - 2020 - GShard Scaling Giant Models with Conditional Computation and Automatic Sharding.pdf;C\:\\Users\\Andakara\\Zotero\\storage\\XKYB7KRK\\2006.html}
}

